# Lab / compose: Kitchen API → Jupiter operator control plane (DV-077)
# Copy into your .env next to docker-compose and set values for your Jupiter host.
#
# KITCHEN_JUPITER_CONTROL_BASE must match the exact base URL the operator UI uses
# to reach Jupiter (scheme + host + port), e.g. http://127.0.0.1:8788
KITCHEN_JUPITER_CONTROL_BASE=
# Token must match Jupiter's operator token (same as UI / runtime config).
KITCHEN_JUPITER_OPERATOR_TOKEN=
