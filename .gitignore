.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Local data (keep directories via .gitkeep)
data/runtime/execution_plane/requests.json
data/runtime/execution_plane/kill_switch.json
# Anna training host runtime (see also named ignores below if you narrow scope)
data/runtime/anna_training/

# Foreman / sequential demo output (host-local)
data/sequential_engine/clawbot_demo/events.txt
data/sequential_engine/clawbot_demo_w10/
data/sequential_engine/web_control/
data/sqlite/*.db
data/sqlite/*.db-journal

# RenaissanceV4 local SQLite (ingest / replay)
renaissance_v4/data/*.sqlite3
renaissance_v4/data/*.sqlite3-journal

# RenaissanceV4: baseline_v1.md is tracked (DV-ARCH-REVIEW-014); do not gitignore.
data/logs/*.log

# Messenger config with real tokens (use messaging_config.example.json + env)
config/messaging_config.json
config/messaging_config.local.json

# SMS distro with real numbers (use notification_recipients.example.json)
config/notification_recipients.local.json

# Hermes PM local env (copy from ops/hermes_pm.env.example)
ops/hermes_pm.env

# Solana keypairs (trading_core / operator)
trading_core/keypair.json
trading_core/keypair.base58

# Local secrets (never commit)
.env
.env.bak
.env.local
.env.*.local
.secrets/

# Context engine local store (host-local; BLACKBOX_CONTEXT_ROOT or default data/context_engine)
data/context_engine/

# macOS
.DS_Store
**/.DS_Store

# Foreman per-cycle JSONL (append-only; can grow large)
docs/working/foreman_v2_cycle_log.jsonl

# UI API runtime snapshot (written by UIUX.Web/api_server.py; default from ensure_state())
docs/working/artifacts/ui_runtime_state.json

# Cursor debug logs
.cursor/debug*.log

# Local secrets / recovery (never commit)
ngrok_recovery_codes.txt

# Local Codex / agent exports (not canonical repo content)
.codex/

# Optional local clones of third-party reference repos
external/

# Optional governance signal bus (local tail / operator; archive separately if needed)
.governance/bus.log

# Operator TLS material for UIUX.Web (fullchain.pem / privkey.pem); keep ssl/.gitkeep only
UIUX.Web/ssl/*.pem
UIUX.Web/ssl/*.key
