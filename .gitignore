data/sequential_engine/clawbot_demo_w10/
data/sequential_engine/web_control/
data/sqlite/*.db
data/sqlite/*.db-journal
data/sqlite/*.db-wal
data/sqlite/*.db-shm

# RenaissanceV4 local SQLite (ingest / replay)
renaissance_v4/data/*.sqlite3
renaissance_v4/data/*.sqlite3-journal

# Operator policy intake uploads (DV-048) — host-local
renaissance_v4/state/policy_intake_submissions/*
!renaissance_v4/state/policy_intake_submissions/clawbot_proof_v1/
!renaissance_v4/state/policy_intake_submissions/clawbot_proof_v1/**
renaissance_v4/state/kitchen_policy_lifecycle_v1.json

# RenaissanceV4: baseline_v1.md is tracked (DV-ARCH-REVIEW-014); do not gitignore.
data/logs/*.log

# Messenger config with real tokens (use messaging_config.example.json + env)
config/messaging_config.json
config/messaging_config.local.json

# SMS distro with real numbers (use notification_recipients.example.json)
config/notification_recipients.local.json

# Hermes PM local env (copy from ops/hermes_pm.env.example)
ops/hermes_pm.env

# Solana keypairs (trading_core / operator)
trading_core/keypair.json
trading_core/keypair.base58

# vscode-test: local override for Jupiter dashboard Basic Auth (defaults are in lab_dashboard_login.defaults.env)
vscode-test/lab_dashboard_login.env
vscode-test/seanv3/.env

# npm (never commit dependency trees)
node_modules/

# Local secrets (never commit)
.env
.env.bak
.env.local
.env.*.local
.secrets/
renaissance_v4/game_theory/unified_agent_v1/config/reasoning_router_secrets.local.json

# PML on lab host: OpenAI key file (see pattern_game_remote_restart.sh)
runtime/secrets/

# Context engine local store (host-local; BLACKBOX_CONTEXT_ROOT or default data/context_engine)
data/context_engine/

# macOS
.DS_Store
**/.DS_Store

# Foreman per-cycle JSONL (append-only; can grow large)
docs/working/foreman_v2_cycle_log.jsonl

# UI API runtime snapshot (written by UIUX.Web/api_server.py; default from ensure_state())
docs/working/artifacts/ui_runtime_state.json

# Cursor debug logs
.cursor/debug*.log

# Local secrets / recovery (never commit)
ngrok_recovery_codes.txt

# Local Codex / agent exports (not canonical repo content)
.codex/

# Optional local clones of third-party reference repos
external/

# Optional governance signal bus (local tail / operator; archive separately if needed)
.governance/bus.log

# Operator TLS material for UIUX.Web (fullchain.pem / privkey.pem); keep ssl/.gitkeep only
UIUX.Web/ssl/*.pem
UIUX.Web/ssl/*.key

# SR-1 / student-loop local scratch DBs (repo root experiments)
_tmp*.sqlite3

# Student Proctor default learning JSONL (host-local; override via PATTERN_GAME_STUDENT_LEARNING_STORE)
runtime/student_learning/

# student_test_mode_v1 isolated harness output (engineering; never commit proof trees)
runtime/student_test/

# GT038 reasoning exam artifacts (host-local exam runs)
runtime/exam/

# GT045 trade-cycle CLI proof output (JSONL + gt045_proof.json per job-id)
runtime/trade_cycle_proof/

# GT048/GT055 harness output (per-job trees under PATTERN_GAME_MEMORY_ROOT)
runtime/gt048_cycle/

# Learning-loop runtime trace JSONL (append-only; host-local under memory root or game_theory)
renaissance_v4/game_theory/learning_trace_events_v1.jsonl
**/learning_trace_events_v1.jsonl

# Loose UI screenshots in game_theory root (avoid accidental gsync commit)
renaissance_v4/game_theory/Screenshot*.png

# FinQuant generated datasets (large JSONL; host sync via scp)
finquant/datasets/*.jsonl
finquant/datasets/staging/
finquant/sources/
finquant/adapters/

# FinQuant agent_lab run outputs (host-local; blocks git pull when tracked/modified)
prove_learning/finquant/unified/agent_lab/outputs/**
!prove_learning/finquant/unified/agent_lab/outputs/.gitkeep
# Alternate checkout layout seen on some lab hosts
finquant/unified/agent_lab/outputs/**
!finquant/unified/agent_lab/outputs/.gitkeep
