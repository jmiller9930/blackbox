#!/usr/bin/env bash
# seanv3py — Sean V3 (Docker) operator: deploy, status, logs, stop, restart.
# Run on clawbot from repo checkout, or anywhere if BLACKBOX_REPO is set.
#
# deploy / restart: host preflight runs BEFORE compose; container check AFTER up (unless skipped).
# Override: SEANV3_SKIP_PREFLIGHT=1 or --skip-preflight
set -euo pipefail

SEAN_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SEAN_DIR/../.." && pwd)"

usage() {
  cat <<'EOF'
Usage: seanv3py <command> [options]

  (For TUI / report / tests in one place, use: python3 seanv3.py tui | report | test)

  deploy     host preflight + docker compose build + up -d + container check
  status     docker compose ps
  logs       docker compose logs -f (follow; Ctrl+C stops tailing only)
  console    persistent tmux session: attach to same session or create (logs -f)
  stop       docker compose down
  restart    stop then deploy (no git pull unless --pull)
  pull       git pull origin main only (from repo root)
  preflight  host checks: Binance ping + klines, capture dir, optional DB/keypair; see --require-container

Options (deploy / restart):
  --pull     Run git pull origin main before compose (default: off for deploy)
  --skip-preflight   Skip host + post-up checks (emergency only; not for normal ops)

Options (preflight):
  --require-container   Also require Docker container seanv3 running + log tail (after deploy)

Environment:
  BLACKBOX_REPO   Override repo root (default: parent of vscode-test/seanv3)
  SEANV3_SKIP_PREFLIGHT=1   Same as --skip-preflight for deploy/restart

Examples:
  ./seanv3py deploy
  ./seanv3py deploy --pull
  ./seanv3py status
  ./seanv3py logs
  ./seanv3py console    # re-run after SSH disconnect reattaches to same tmux (see SEANV3PY.md)
  ./seanv3py preflight
  ./seanv3py preflight --require-container

Environment (console):
  SEANV3_TMUX_SESSION   tmux session name (default: seanv3)

EOF
}

cd "$SEAN_DIR"

repo_root() {
  if [[ -n "${BLACKBOX_REPO:-}" ]]; then
    echo "${BLACKBOX_REPO}"
  else
    echo "$REPO_ROOT"
  fi
}

do_pull() {
  local root
  root="$(repo_root)"
  echo "[seanv3py] git pull in $root"
  git -C "$root" pull origin main
}

do_compose() {
  # shellcheck disable=SC2068
  docker compose "$@"
}

# Same origin as scripts/runtime/market_data/public_data_urls.py (default api.binance.com).
_binance_origin() {
  local o="${BINANCE_API_BASE_URL:-${BINANCE_REST_BASE_URL:-https://api.binance.com}}"
  o="${o%/}"
  echo "$o"
}

# Steps 1–6: must pass before we start or replace the stack. Returns 0 if OK, 1 if fail.
preflight_host_phase() {
  local fail=0
  local tmpfile
  tmpfile="$(mktemp)" || {
    echo "[preflight] FAIL: mktemp"
    return 1
  }
  # shellcheck disable=SC2064
  trap "rm -f \"$tmpfile\"" RETURN

  local bo
  bo="$(_binance_origin)"

  echo "[preflight] 1. Binance GET /api/v3/ping (expect HTTP 200) ..."
  local code
  code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 20 "${bo}/api/v3/ping")"
  if [[ "$code" != "200" ]]; then
    echo "[preflight] FAIL: ping HTTP $code (expect 200; 451 often means wrong egress — VPN/README.md)"
    fail=1
  else
    echo "[preflight] OK: ping $code"
  fi

  echo "[preflight] 2. Binance GET /api/v3/klines SOLUSDT 5m limit=1 (expect HTTP 200 + JSON array) ..."
  code="$(curl -sS -o "$tmpfile" -w '%{http_code}' --max-time 20 "${bo}/api/v3/klines?symbol=SOLUSDT&interval=5m&limit=1")"
  if [[ "$code" != "200" ]]; then
    echo "[preflight] FAIL: klines HTTP $code"
    fail=1
  else
    if head -c 1 "$tmpfile" | grep -q '\['; then
      echo "[preflight] OK: klines body is a JSON array"
    else
      echo "[preflight] FAIL: klines body does not look like a JSON array"
      fail=1
    fi
  fi

  echo "[preflight] 3. docker-compose.yml network_mode: host (required for Binance via host WG) ..."
  if grep -qE '^[[:space:]]*network_mode:[[:space:]]*host[[:space:]]*$' docker-compose.yml; then
    echo "[preflight] OK: network_mode host"
  else
    echo "[preflight] FAIL: network_mode: host missing — Binance may return 451"
    fail=1
  fi

  echo "[preflight] 4. capture/ writable (bind mount for NDJSON + SQLite) ..."
  mkdir -p capture
  if touch capture/.seanv3_preflight_write 2>/dev/null; then
    rm -f capture/.seanv3_preflight_write
    echo "[preflight] OK: capture/ writable"
  else
    echo "[preflight] FAIL: capture/ not writable"
    fail=1
  fi

  echo "[preflight] 5. SQLite sean_parity.db (if present) ..."
  if [[ -f capture/sean_parity.db ]]; then
    if command -v sqlite3 >/dev/null 2>&1; then
      if sqlite3 capture/sean_parity.db "SELECT 1 FROM sqlite_master WHERE type='table' AND name='sean_binance_kline_poll' LIMIT 1;" 2>/dev/null | grep -q 1; then
        echo "[preflight] OK: table sean_binance_kline_poll exists"
      else
        echo "[preflight] WARN: DB file exists but sean_binance_kline_poll missing (first app run creates it)"
      fi
    else
      echo "[preflight] WARN: sqlite3 not installed — skipping schema check"
    fi
  else
    echo "[preflight] INFO: sean_parity.db not yet (created on first successful poll)"
  fi

  echo "[preflight] 6. Wallet keypair (optional) ..."
  if [[ -f capture/keypair.json ]]; then
    if python3 -c "import json; json.load(open('capture/keypair.json'))" 2>/dev/null; then
      echo "[preflight] OK: capture/keypair.json is valid JSON (enable KEYPAIR_PATH in compose to use)"
    else
      echo "[preflight] FAIL: capture/keypair.json is not valid JSON"
      fail=1
    fi
  else
    echo "[preflight] INFO: no capture/keypair.json (optional unless KEYPAIR_PATH uncommented in compose)"
  fi

  return "$fail"
}

# After compose up: container must be running. Returns 0 if OK, 1 if fail.
preflight_container_phase() {
  local fail=0
  echo "[preflight] 7. Docker container seanv3 running ..."
  if docker inspect -f '{{.State.Running}}' seanv3 2>/dev/null | grep -q true; then
    echo "[preflight] OK: container seanv3 is running"
    echo "[preflight] 8. Recent logs (last 15 lines) ..."
    do_compose logs --tail=15 seanv3 2>/dev/null || do_compose logs --tail=15 2>/dev/null || true
  else
    echo "[preflight] FAIL: container seanv3 not running after compose up"
    fail=1
  fi
  return "$fail"
}

parse_deploy_restart_flags() {
  pull_flag=0
  skip_pf=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pull) pull_flag=1 ;;
      --skip-preflight) skip_pf=1 ;;
      *)
        echo "Unknown option: $1" >&2
        usage
        exit 1
        ;;
    esac
    shift
  done
  case "${SEANV3_SKIP_PREFLIGHT:-}" in
    1|true|yes|on|TRUE|YES|ON) skip_pf=1 ;;
  esac
}

cmd="${1:-}"
shift || true

case "$cmd" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;
  deploy)
    parse_deploy_restart_flags "$@"
    if [[ "$pull_flag" -eq 1 ]]; then
      do_pull
    fi
    if [[ "$skip_pf" -eq 0 ]]; then
      echo "[seanv3py] Host preflight (must pass before compose; SEANV3_SKIP_PREFLIGHT=1 or --skip-preflight to bypass) ..."
      if ! preflight_host_phase; then
        echo "[seanv3py] ABORT: host preflight failed — fix VPN/README.md, capture/, or compose. Stack not started."
        exit 1
      fi
    fi
    echo "[seanv3py] docker compose build + up -d ($SEAN_DIR)"
    do_compose build
    do_compose up -d
    if [[ "$skip_pf" -eq 0 ]]; then
      echo "[seanv3py] Post-up: container check ..."
      if ! preflight_container_phase; then
        echo "[seanv3py] ABORT: container not healthy. Try: docker compose logs seanv3"
        exit 1
      fi
    fi
    echo "[seanv3py] done. Status:"
    do_compose ps
    echo "[seanv3py] Paper stack is PAPER_TRADING=1 (see docker-compose.yml) — not live exchange orders."
    ;;
  status|ps)
    do_compose ps -a
    ;;
  logs)
    do_compose logs -f
    ;;
  console|tmux)
    TMUX_SESSION="${SEANV3_TMUX_SESSION:-seanv3}"
    if ! command -v tmux >/dev/null 2>&1; then
      echo "[seanv3py] tmux not found. Install: sudo apt install tmux" >&2
      echo "[seanv3py] Or use: ./seanv3py logs   (no persistent pane)" >&2
      exit 1
    fi
    echo "[seanv3py] tmux session: $TMUX_SESSION (detach: Ctrl+b then d | reattach: ./seanv3py console)"
    exec tmux new-session -A -s "$TMUX_SESSION" -c "$SEAN_DIR" sh -c 'exec docker compose logs -f'
    ;;
  stop|down)
    echo "[seanv3py] docker compose down"
    do_compose down
    ;;
  restart)
    parse_deploy_restart_flags "$@"
    if [[ "$skip_pf" -eq 0 ]]; then
      echo "[seanv3py] Host preflight (before restart) ..."
      if ! preflight_host_phase; then
        echo "[seanv3py] ABORT: host preflight failed — not restarting stack."
        exit 1
      fi
    fi
    do_compose down
    if [[ "$pull_flag" -eq 1 ]]; then
      do_pull
    fi
    do_compose build
    do_compose up -d
    if [[ "$skip_pf" -eq 0 ]]; then
      echo "[seanv3py] Post-up: container check ..."
      if ! preflight_container_phase; then
        echo "[seanv3py] ABORT: container not healthy. Try: docker compose logs seanv3"
        exit 1
      fi
    fi
    do_compose ps
    echo "[seanv3py] Paper stack is PAPER_TRADING=1 (see docker-compose.yml) — not live exchange orders."
    ;;
  pull)
    do_pull
    ;;
  preflight)
    require_container=0
    if [[ "${1:-}" == "--require-container" ]]; then
      require_container=1
    fi
    fail=0
    if ! preflight_host_phase; then
      fail=1
    fi
    if [[ "$require_container" -eq 1 ]]; then
      if ! preflight_container_phase; then
        fail=1
      fi
    fi
    if [[ "$fail" -ne 0 ]]; then
      echo "[preflight] FAILED — fix items above before relying on parity / paper run."
      exit 1
    fi
    echo "[preflight] All automated checks passed."
    echo "[preflight] Reminder: this stack is PAPER_TRADING=1 parity (see docker-compose.yml) — not live exchange orders."
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
