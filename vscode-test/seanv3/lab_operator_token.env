# Lab-only: HTTP operator secret for jupiter-web POST /api/operator/* (not a Solana wallet key).
# Docker Compose loads this into the jupiter-web container. Rotate if this tree is exposed beyond trust.
# JUPITER_WEB_PREFILL_BEARER=1 makes /dashboard pre-fill the Bearer field (convenience; still HTTPS/VPN-restrict in prod).
JUPITER_OPERATOR_TOKEN=51120f9946b67fdaf6a37dde696f89dd8a52e0bf
JUPITER_WEB_PREFILL_BEARER=1
JUPITER_WEB_READ_ONLY=1
