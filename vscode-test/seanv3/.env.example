# Copy to .env in this directory (gitignored). Used by docker compose variable substitution.
# Required when lab_dashboard_login.defaults.env sets JUPITER_AUTH_MODE=session:
JUPITER_SESSION_SECRET=

# When Jupiter is behind HTTPS — Jupiter-only Caddy sidecar (docker-compose.jupiter-https.yml, host :8443):
# JUPITER_PUBLIC_BASE_URL=https://your.hostname:8443
# JUPITER_SESSION_COOKIE_SECURE=1
# Omit JUPITER_SESSION_COOKIE_SECURE (or leave not 1) if operators use plain http://…:707 only.

# Login username defaults to admin (see JUPITER_AUTH_USERNAME in lab_dashboard_login.defaults.env).
# Bootstrap password can stay in defaults env or override here:
# JUPITER_AUTH_BOOTSTRAP_PASSWORD=

# Password reset — use Gmail SMTP (recommended for a personal inbox) OR Resend.
# SMTP is used when JUPITER_SMTP_HOST, JUPITER_SMTP_USER, and JUPITER_SMTP_PASS are all set.
#
# Gmail: enable 2-Step Verification, then create an App Password (Google Account → Security).
# JUPITER_SMTP_HOST=smtp.gmail.com
# JUPITER_SMTP_PORT=587
# JUPITER_SMTP_USER=you@gmail.com
# JUPITER_SMTP_PASS=your-16-char-app-password
# Optional: JUPITER_SMTP_FROM=Jupiter Lab <you@gmail.com>   (defaults to Jupiter Lab <user>)
# Port 465: set JUPITER_SMTP_PORT=465 and JUPITER_SMTP_SECURE=1
# Non-Gmail port 587: STARTTLS is on by default (requireTLS). Set JUPITER_SMTP_REQUIRE_TLS=0 to disable.
# Verbose SMTP wire (passwords appear in logs — lab only): JUPITER_SMTP_DEBUG=1
#
# Alternative — Resend API (https://resend.com):
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Jupiter Lab <onboarding@resend.dev>
# Recipient for resets: JUPITER_AUTH_EMAIL in ../lab_dashboard_login.defaults.env
