# Copy to .env in this directory (gitignored). Used by docker compose variable substitution.
# Required when lab_dashboard_login.defaults.env sets JUPITER_AUTH_MODE=session:
JUPITER_SESSION_SECRET=

# Login username defaults to admin (see JUPITER_AUTH_USERNAME in lab_dashboard_login.defaults.env).
# Bootstrap password can stay in defaults env or override here:
# JUPITER_AUTH_BOOTSTRAP_PASSWORD=

# Optional — emailed reset links (https://resend.com):
# RESEND_API_KEY=
# RESEND_FROM=Jupiter <onboarding@resend.dev>
