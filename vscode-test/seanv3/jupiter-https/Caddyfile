# Jupiter-only HTTPS — separate from BlackBox UIUX.Web (does not use host :443).
# Listens on :443 inside the jupiter-https container; compose maps host :8443 → this.
# Upstream: jupiter-web on the host at :707 (HTTP).
#
# First-time: browser will warn on self-signed (tls internal). For a public hostname with DNS
# pointed at this host, replace this file with Caddyfile.public.example and a real server name,
# or mount Let's Encrypt files — see README in seanv3/.

{
	admin off
}

:443 {
	tls internal
	reverse_proxy host.docker.internal:707
}
