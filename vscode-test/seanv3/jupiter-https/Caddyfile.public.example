# Example: public hostname + automatic HTTPS (Let's Encrypt) via Caddy.
# Copy to Caddyfile (or swap filenames) when DNS for this name points at this host :8443
# and ports 80/443 are reachable for ACME — OR use DNS challenge (see Caddy docs).
#
# If BlackBox already uses :80/:443 on this machine, HTTP-01 may conflict; prefer tls internal
# on :8443, DNS-01, or mount certs from certbot into a tls {} block instead.

# your.jupiter.example.com {
# 	reverse_proxy host.docker.internal:707
# }
