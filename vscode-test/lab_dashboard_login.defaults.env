# Jupiter browser auth (vscode-test/seanv3/docker-compose → jupiter-web).
# Login: username (default admin) + password — not email. Email is only for password-reset messages.
#
# Required: JUPITER_SESSION_SECRET (≥16 chars) in vscode-test/seanv3/.env
# Optional: set JUPITER_SMTP_* (Gmail) or RESEND_API_KEY in vscode-test/seanv3/.env for inbox delivery; else reset URL is only in docker logs.
JUPITER_AUTH_MODE=session
JUPITER_AUTH_USERNAME=admin
# First-time DB login seed (remove or rotate after deploy). Spelling: Crypt (not Cyrpt).
JUPITER_AUTH_BOOTSTRAP_PASSWORD=Crypt0Kings!
JUPITER_AUTH_EMAIL=jmiller9930@om3.us
# Public URL for password-reset links — must match what operators type in the browser (scheme + host + port).
# WAN HTTP: http://jupv3.greyllc.net:707 (WAN :707 → host :707; Jupiter is HTTP only on that port).
# Never use https:// on :707 — Node does not speak TLS there. For HTTPS use Caddy on host :8443 (see README).
# VPN-only: override in seanv3/.env to http://clawbot.a51.corp:707 if you never use the WAN hostname.
# WAN HTTPS (different port): https://jupv3.greyllc.net:8443 + docker-compose.jupiter-https.yml; forward WAN :8443 → host :8443; JUPITER_SESSION_COOKIE_SECURE=1; JUPITER_PUBLIC_BASE_URL=https://jupv3.greyllc.net:8443
JUPITER_PUBLIC_BASE_URL=http://jupv3.greyllc.net:707
