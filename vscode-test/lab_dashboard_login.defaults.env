# Jupiter browser auth (loaded by vscode-test/seanv3/docker-compose for jupiter-web).
# Session login + email reset — no plaintext passwords here; set secrets in vscode-test/seanv3/.env (gitignored) or host env.
#
# Required for JUPITER_AUTH_MODE=session: JUPITER_SESSION_SECRET (≥16 chars) — e.g. openssl rand -hex 24
# Optional: RESEND_API_KEY + RESEND_FROM for emailed reset links; if unset, reset URL is logged to container stderr.
# One-time bootstrap: JUPITER_AUTH_BOOTSTRAP_PASSWORD (then remove) OR use Forgot password after Resend works.
JUPITER_AUTH_MODE=session
JUPITER_AUTH_EMAIL=jmiller9930@om3.us
JUPITER_PUBLIC_BASE_URL=http://clawbot.a51.corp:707
