# ====================== INDICATOR HELPERS (exact match to TS) ======================

def _ema(series: List[float], period: int) -> List[float]:
    """Exact EMA implementation from TS (initial SMA then exponential smoothing)."""
    n = len(series)
    if n < period:
        return [float('nan')] * n
    ema_values: List[float] = [float('nan')] * n
    initial_sum = sum(series[:period])
    ema_values[period - 1] = initial_sum / period
    alpha = 2.0 / (period + 1)
    for i in range(period, n):
        ema_values[i] = series[i] * alpha + ema_values[i - 1] * (1 - alpha)
    return ema_values


def _rsi(series: List[float], period: int = RSI_PERIOD) -> List[float]:
    """Exact RSI implementation matching the fixed version in latest TS (index fix + safe avgLoss)."""
    n = len(series)
    if n < period + 1:
        return [float('nan')] * n
    rsi_values: List[float] = [float('nan')] * n
    gain = 0.0
    loss = 0.0
    for i in range(1, period + 1):
        delta = series[i] - series[i - 1]
        if delta > 0:
            gain += delta
        else:
            loss -= delta
    avg_gain = gain / period
    avg_loss = max(loss / period, 0.001)
    rs = float('inf') if avg_loss == 0 else avg_gain / avg_loss
    rsi_values[period - 1] = 100 - (100 / (1 + rs))
    for i in range(period, n):
        delta = series[i] - series[i - 1]
        current_gain = max(delta, 0.0)
        current_loss = max(-delta, 0.0)
        avg_gain = (avg_gain * (period - 1) + current_gain) / period
        avg_loss = max((avg_loss * (period - 1) + current_loss) / period, 0.001)
        rs = float('inf') if avg_loss == 0 else avg_gain / avg_loss
        rsi_values[i] = 100 - (100 / (1 + rs))
    return rsi_values


def _atr(closes: List[float], highs: List[float], lows: List[float], period: int = ATR_PERIOD) -> float:
    """Exact ATR implementation from TS."""
    n = len(closes)
    if n < period + 1:
        return 0.25
    tr_sum = 0.0
    for i in range(1, period + 1):
        high = highs[n - i]
        low = lows[n - i]
        prev_close = closes[n - i - 1]
        tr1 = high - low
        tr2 = abs(high - prev_close)
        tr3 = abs(low - prev_close)
        tr_sum += max(tr1, tr2, tr3)
    return tr_sum / period


def _calculate_confidence_score(bullish_bias: bool, rsi: float) -> int:
    """Exact confidence scoring logic from latest TS calculateConfidenceScore."""
    score = 2
    if (bullish_bias and rsi >= RSI_LONG_THRESHOLD) or (not bullish_bias and rsi <= RSI_SHORT_THRESHOLD):
        score += 3
    return min(10, score)


# ====================== PUBLIC GATE & EVALUATOR ======================

def jupiter_v4_gates(df: pd.DataFrame) -> Tuple[bool, bool]:
    """Raw long/short gate booleans (exact 2-candle divergence logic from TS aggregateCandles).

    Long gate predicate:
        previous_bias == LONG
        AND bullish_divergence = (current.low < previous.low) AND (current.rsi > previous.rsi)

    Short gate predicate (symmetric):
        previous_bias == SHORT AND bearish_divergence.

    previous_bias is computed from EMA9/21 at candle[-2] to avoid look-ahead.
    Requires at least EMA_LONG_PERIOD + 2 bars.
    """
    if len(df) < EMA_LONG_PERIOD + 2:
        return False, False

    closes = df["close"].tolist()
    ema9_vals = _ema(closes, EMA_SHORT_PERIOD)
    ema21_vals = _ema(closes, EMA_LONG_PERIOD)
    rsi_vals = _rsi(closes, RSI_PERIOD)

    if len(ema9_vals) < 2 or len(ema21_vals) < 2 or len(rsi_vals) < 2:
        return False, False

    # Previous bias (before current candle)
    ema9_prev = ema9_vals[-2]
    ema21_prev = ema21_vals[-2]
    previous_bias = ema9_prev > ema21_prev   # True = LONG bias

    # 2-candle divergence (exactly as in latest TS)
    current_candle = df.iloc[-1]
    previous_candle = df.iloc[-2]

    current_rsi = rsi_vals[-1] if not pd.isna(rsi_vals[-1]) else 50.0
    prev_rsi = rsi_vals[-2]

    bullish_divergence = (current_candle["low"] < previous_candle["low"]) and (current_rsi > prev_rsi)
    bearish_divergence = (current_candle["high"] > previous_candle["high"]) and (current_rsi < prev_rsi)

    long_gate = previous_bias and bullish_divergence
    short_gate = (not previous_bias) and bearish_divergence

    return long_gate, short_gate


def evaluate_jupiter_v4(
    df: pd.DataFrame,
    current_price: float,
    free_collateral_usd: float,
    current_position: int = 0,
) -> Dict[str, Any]:
    """Full JUPv4 policy evaluator – returns structured diagnostics dict.

    Args:
        df (pd.DataFrame): 15m OHLCV historical data.
        current_price (float): latest Pyth price.
        free_collateral_usd (float): available collateral (direction-aware).
        current_position (int): current position for flip awareness.

    Returns:
        dict with every key documented below.

    Raises:
        ValueError: if df columns are missing.

    Side effects: None (pure function).

    Diagnostics keys (all explained):
        - long_gate / short_gate: bool – exact 2-candle divergence predicates.
        - signal: "long", "short", or None.
        - confidence_score: int (2 or 5).
        - risk_pct: float – BASE / 0.020 / MAX.
        - collateral_usd: float – actual dollars allocated.
        - recommended_leverage: int – 10/20/30x.
        - leverage_reason: str.
        - atr, rsi: raw values.
        - diagnostics: previous_bias, divergence flags, body-based TP/SL parameters, dynamic/ratcheting rules, manual position flag.
    """
    if not {"open", "high", "low", "close", "volume"}.issubset(df.columns):
        raise ValueError("df must contain OHLCV columns")

    long_gate, short_gate = jupiter_v4_gates(df)

    if len(df) < EMA_LONG_PERIOD + 2:
        return {
            "long_gate": False,
            "short_gate": False,
            "signal": None,
            "confidence_score": 0,
            "risk_pct": 0.0,
            "collateral_usd": 0.0,
            "recommended_leverage": 10,
            "leverage_reason": "insufficient_data",
            "atr": 0.0,
            "rsi": 50.0,
            "diagnostics": {
                "reason": "insufficient_data",
                "sufficient_data": False,
                "previous_bias": None,
                "bullish_divergence": False,
                "bearish_divergence": False,
                "is_manual_position": False,
            },
        }

    # Re-compute latest indicators
    closes = df["close"].tolist()
    highs = df["high"].tolist()
    lows = df["low"].tolist()
    rsi_vals = _rsi(closes, RSI_PERIOD)
    atr_val = _atr(closes, highs, lows, ATR_PERIOD)

    current_rsi = rsi_vals[-1] if not pd.isna(rsi_vals[-1]) else 50.0

    # Bias for confidence scoring
    ema9_vals = _ema(closes, EMA_SHORT_PERIOD)
    bullish_bias = ema9_vals[-1] > _ema(closes, EMA_LONG_PERIOD)[-1] if len(ema9_vals) > 0 else False

    confidence_score = _calculate_confidence_score(bullish_bias, current_rsi)

    # Dynamic sizing (exact match to TS processSignals)
    risk_pct = BASE_RISK_PCT
    if confidence_score >= 8:
        risk_pct = MAX_RISK_PCT
    elif confidence_score >= 6:
        risk_pct = 0.020

    collateral_usd = free_collateral_usd * risk_pct
    if free_collateral_usd < MIN_COLLATERAL_USD:
        collateral_usd = 0.0

    # Leverage
    if confidence_score >= 8:
        leverage = 30
        lev_reason = "high_confidence_(8-10)"
    elif confidence_score >= 6:
        leverage = 20
        lev_reason = "medium_confidence_(6-7)"
    else:
        leverage = 10
        lev_reason = "low_confidence"

    signal = "long" if long_gate else "short" if short_gate else None

    return {
        "long_gate": long_gate,
        "short_gate": short_gate,
        "signal": signal,
        "confidence_score": confidence_score,
        "risk_pct": risk_pct,
        "collateral_usd": round(collateral_usd, 2),
        "recommended_leverage": leverage,
        "leverage_reason": lev_reason,
        "atr": round(atr_val, 6),
        "rsi": round(current_rsi, 2),
        "diagnostics": {
            "previous_bias": "LONG" if bullish_bias else "SHORT",
            "bullish_divergence": long_gate,
            "bearish_divergence": short_gate,
            "sufficient_data": True,
            "current_price_used": current_price,
            "free_collateral_usd": round(free_collateral_usd, 2),
            "current_position": current_position,
            "is_manual_position": False,  # policy cannot know; executor sets from on-chain adopt
            "body_tp_multiplier": BODY_TP_MULTIPLIER,
            "min_sl_pct": MIN_SL_PCT,
            "min_body_pct_floor": MIN_BODY_PCT_FLOOR,
            "spread_buffer_pct": SPREAD_BUFFER_PCT,
            "dynamic_tp_update_ms": DYNAMIC_TP_UPDATE_MS,
            "note": "Body-based TP/SL (4× effective body, 0.7% SL floor + spread buffer) + dynamic TP (15s updates clamped to originalCandleTp) + ratcheting SL (candle close) is guidance for live executor only. Manual positions never auto-flip.",
        },
    }



