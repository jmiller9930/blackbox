# Copy to `.env` on the lab host and set Ollama to a reachable URL (loaded by Python via
# `modules/anna_training/repo_env.py` and by `scripts/anna_karpathy_loop_env.inc.sh`).
#
# Example when Ollama runs on another machine on the lab LAN:
# OLLAMA_BASE_URL=http://172.20.2.230:11434
#
# Default in code when unset is http://127.0.0.1:11434 — only works if ollama serve runs locally.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional — must exist in `ollama list` / /api/tags when using the LLM
# OLLAMA_MODEL=qwen2.5:7b

# Karpathy: default maps OBSERVATION_ONLY → CONDITION_TIGHTENING for execution_request wiring.
# Opt out of that (strict observational): ANNA_KARPATHY_DISABLE_LAB_WIRE_JACK=1
# BLACKBOX_JACK_EXECUTOR_CMD=...
