# Copy to `.env` and/or `.env.local` (gitignored). Never commit real values.
# Karpathy loop (`scripts/anna_karpathy_loop_run.sh`, `anna_karpathy_loop_server.sh`) loads
# `.env` then `.env.local` so OLLAMA_BASE_URL applies to the daemon (same as _ollama.py).
# OpenClaw Control UI: paste Gateway Token from `gateway.auth.token` in ~/.openclaw/openclaw.json on the gateway host.
OPENCLAW_GATEWAY_TOKEN=
#
# Slack DM replies are handled by the OpenClaw gateway on the host (not by messaging_interface/slack_adapter.py
# unless you run that backend explicitly). If Slack shows nothing but the gateway runs, check session logs on
# the host and avoid models that only emit the silent NO_REPLY token; prefer general instruct models for chat
# (e.g. ollama/qwen2.5:7b or llama3.1:8b locally). For OpenAI-class quality, configure the gateway host’s
# ~/.openclaw/openclaw.json models + provider secrets (e.g. OPENAI_API_KEY) per OpenClaw docs — typical picks:
# gpt-4o (strong) or gpt-4o-mini (cheaper).

# Anna / runtime LLM (Ollama): single source of truth on clawbot — set the network LLM host.
# If unset, Anna defaults to http://127.0.0.1:11434 (scripts/runtime/_ollama.py) and will fail if nothing listens there.
# Align with the gateway host’s OpenClaw Ollama baseUrl in ~/.openclaw/openclaw.json (same host:port as embedded ollama).
# OLLAMA_BASE_URL=http://172.20.2.230:11434
# (example lab host; use your Ollama listener — not 127.0.0.1 unless Ollama runs locally)
# OLLAMA_MODEL=qwen2.5:7b
# (general instruct; not qwen *coder* for Anna — per architect)
# Optional: OLLAMA_STRICT=1  # require OLLAMA_BASE_URL (fail fast if unset)
# ANNA_USE_LLM=1   # default on; set 0 for offline/tests
# ANNA_TELEGRAM_USE_LLM=1  # optional: Telegram-only override (else follows ANNA_USE_LLM)

# Messaging (Directive 4.6.3.4) — optional overrides when using config/messaging_config.json
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# Architect Slack closure (stderr JSON per DM / subprocess): SLACK_ARCHITECT_DIAGNOSTICS=1
# Optional: pass ingress user text into OpenClaw persona bridge logs: SLACK_ARCHITECT_INGRESS_USER_TEXT="..."
